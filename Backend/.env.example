# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/attendance_db

# Option 2: MongoDB Atlas (recommended for production)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/attendance_db?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHARACTER_RANDOM_STRING_IN_PRODUCTION_!!
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://your-app.vercel.app